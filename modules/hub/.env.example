# ── SchedulerDefaults (module: app.common.config) ──
## Default global timeout for scheduled tasks in seconds (int)
# GLOBAL_TIMEOUT_SECONDS=300

## Buffer time to subtract from the global timeout to ensure tasks complete within limits in seconds (int)
# GLOBAL_TIMEOUT_BUFFER=30

## Maximum number of concurrent tasks that can be scheduled (int)
# MAX_CONCURRENT_TASKS=10

## Maximum number of retry attempts for failed tasks (int)
# MAX_RETRY_ATTEMPTS=3

## Maximum number of schedules or retry jobs to fetch in a single tick (int)
# MAX_DISPATCH_LIMIT=200


# ── AppSettings (module: app_base.config.config) ──
## SQLAlchemy async database connection URL (defaults to SQLite) (str, auto-generated)
# DATABASE_URL=

## Absolute path to the log file (str, auto-generated)
# LOG_PATH=

## Emit logs in JSON format when True (useful for log aggregators) (bool)
# LOG_JSON_FORMAT=False

## Minimum log level to emit (DEBUG, INFO, WARNING, ERROR, CRITICAL) (str)
# LOG_LEVEL=INFO

## Shorten tracebacks to only show frames matching the whitelist (bool)
# LOG_SIMPLE_TRACEBACK=True

## List of module name prefixes included in simplified tracebacks (list[str], auto-generated)
# LOG_TRACEBACK_WHITELIST=

## Explicit list of allowed CORS origins (list[str], auto-generated)
# CORS_ALLOWED_ORIGINS=

## Regex pattern matching allowed CORS origins (str | None)
# CORS_ALLOW_ORIGIN_REGEX=

## Allow cookies and credentials to be included in CORS requests (bool)
# CORS_ALLOW_CREDENTIALS=False

